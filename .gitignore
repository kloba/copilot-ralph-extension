node_modules/
.DS_Store
*.log
.copilot/

# Never commit local environment files — they routinely contain
# credentials (API tokens, database URLs). The `.env*` pattern catches
# `.env`, `.env.local`, `.env.test`, etc., so a contributor running
# tooling that auto-loads dotenv cannot accidentally leak secrets via
# `git add -A`. The extension itself does not use dotenv (see
# `extension/handler.mjs` — only `process.env` lookups), but contributor
# tooling (asciinema recipes, ad-hoc scripts) often does.
.env
.env.*

# Coverage reports from any future `c8` / `nyc` invocation.
coverage/

# Output of `npm pack` / `npm publish --dry-run` so a packed tarball
# left in the repo root is not accidentally committed.
*.tgz

# mkdocs build output. `mkdocs build` writes the rendered static
# site here by default (see mkdocs.yml — no `site_dir` override).
# A contributor previewing the docs locally would otherwise sweep
# the entire generated site into a `git add -A`, polluting the
# repo with rebuilt artefacts on every commit.
site/


# Output of `./install.sh --project` from inside this repo.
# The script writes a working copy of the extension under
# `.github/extensions/ralph/` (so tools that load extensions from
# `.github/extensions/<name>/` see this repo's own extension while
# you dogfood), but committing that working copy creates a second
# source of truth that drifts from `extension/` on every iter.
.github/extensions/ralph/
